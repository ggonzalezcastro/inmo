# IMPORTANTE: NUNCA commits el archivo .env con valores reales
# Copia este archivo a .env y reemplaza con tus valores reales
# Generar SECRET_KEY con: openssl rand -hex 32

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
# Uvicorn en la Mac + Postgres en Docker: usa 127.0.0.1, no el hostname "db" (solo válido dentro de Docker).
# Si el puerto 5432 del host está ocupado: POSTGRES_HOST_PORT=5433 docker compose up -d db
#   → DATABASE_URL=postgresql+asyncpg://lead_user:lead_pass_123@127.0.0.1:5433/lead_agent

# Redis
REDIS_URL=redis://localhost:6379/0
# Mismo caso puerto ocupado: REDIS_HOST_PORT=6380 docker compose up -d redis → redis://127.0.0.1:6380/0

# Security
SECRET_KEY=your-super-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MiniMax (pre-commit doc review agent)
MINIMAX_API_KEY=your_minimax_api_key_here

# LLM Providers
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# 1500 tokens: system prompt (~400t) + history (~600t) + response headroom (~500t)
GEMINI_MAX_TOKENS=1500
GEMINI_TEMPERATURE=0.7
# Context caching: enable in prod once system prompt exceeds ~4096 tokens (e.g. after TASK-024 RAG)
GEMINI_CONTEXT_CACHING_ENABLED=false
GEMINI_CONTEXT_CACHE_TTL=3600
GEMMA_MODEL=gemma-4-31b-it
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=2048
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=
OPENAI_MAX_TOKENS=2048
# Primary LLM provider. Options: gemini, claude, openai
LLM_PROVIDER=gemini
# Automatic failover provider when primary fails. Leave empty to disable router.
LLM_FALLBACK_PROVIDER=claude
# Semantic cache (Redis-backed cosine similarity) — disable to reduce Redis load.
SEMANTIC_CACHE_ENABLED=true

# MCP Tool Server
# "http" = standalone microservice (recommended for production, required in docker-compose)
# "stdio" = subprocess per-singleton (development fallback only)
MCP_TRANSPORT=http
MCP_SERVER_URL=http://localhost:8001
MCP_SERVER_PORT=8001

# Telegram
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhooks/telegram
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# WhatsApp (Meta Cloud API)
# Callback URL in Meta Developer Console → WhatsApp → Configuration → Webhook:
#   https://<tu-dominio-o-ngrok>/webhooks/whatsapp
# Subscribe to field: messages
# After changing .env, restart the API. For inbound replies you also need Celery worker + Redis.
WHATSAPP_ACCESS_TOKEN=your_permanent_or_system_user_token
WHATSAPP_PHONE_NUMBER_ID=from_meta_api_setup_phone_number_id
# String you invent; must match "Verify token" in Meta webhook form
WHATSAPP_VERIFY_TOKEN=your_random_verify_string
# Meta App Secret (Settings → Basic) — used for X-Hub-Signature-256 on POST webhooks
WHATSAPP_WEBHOOK_SECRET=your_meta_app_secret

# VAPI
VAPI_API_KEY=your_vapi_api_key_here
VAPI_PHONE_NUMBER_ID=your_phone_number_id_here
VAPI_ASSISTANT_ID=your_assistant_id_here
WEBHOOK_BASE_URL=http://localhost:8000

# Google Calendar
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json
# OAuth per-broker: redirect URI must be registered in Google Cloud Console
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/broker/calendar/callback
# Frontend URL for post-OAuth redirect
FRONTEND_URL=http://localhost:5173

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Si Redis del compose está en 6380: redis://127.0.0.1:6380/1 y .../2

# Microsoft Outlook Calendar (per-broker OAuth)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_OAUTH_REDIRECT_URI=

# Observability — OpenTelemetry / Sentry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=inmo-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
SENTRY_DSN=

# Docker host port overrides (when 5432/6379 ya están ocupados en el host)
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# Environment
DEBUG=False
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000