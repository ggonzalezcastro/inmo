{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "build": {
        "builder": "nixpacks",
        "buildCommand": "cd backend && pip install -r requirements.txt"
      },
      "deploy": {
        "startCommand": "cd backend && sh -c 'alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port $PORT --log-level warning'",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    },
    "celery-worker": {
      "build": {
        "builder": "dockerfile",
        "dockerfile": "backend/Dockerfile.celery-worker"
      },
      "deploy": {
        "startCommand": "cd backend && celery -A app.celery_app worker --loglevel=info --concurrency=4",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    },
    "celery-beat": {
      "build": {
        "builder": "dockerfile",
        "dockerfile": "backend/Dockerfile.celery-beat"
      },
      "deploy": {
        "startCommand": "cd backend && celery -A app.celery_app beat --loglevel=info",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    },
    "frontend": {
      "build": {
        "builder": "nixpacks"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    }
  }
}
